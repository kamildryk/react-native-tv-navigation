{
  "name": "react-native-tv-navigation",
  "version": "0.1.0",
  "description": "React Native TV TouchableOpacity wrapper with native forced directional focus.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
